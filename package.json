{
  "name": "@jod/urataidot-ui",
  "version": "0.0.0",
  "private": true,
  "license": "EUPL-1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "oxlint",
    "format": "oxfmt",
    "preview": "vite preview",
    "test:unit": "vitest --run",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "translations:check": "node ./scripts/translations/analyze-translations.js",
    "translations:fetch": "node ./scripts/translations/fetch-translations.js",
    "translations:push": "tolgee push",
    "translations:tag": "node ./scripts/translations/manage-tags.js",
    "translations:tag:dry": "node ./scripts/translations/manage-tags.js --dry-run"
  },
  "dependencies": {
    "@headlessui/react": "2.2.9",
    "@hookform/error-message": "2.0.1",
    "@hookform/resolvers": "5.2.2",
    "@jod/design-system": "https://github.com/Opetushallitus/jod-design-system/releases/download/rel-20260511-1/jod-design-system-0.0.0.tgz",
    "@react-pdf/renderer": "4.3.2",
    "cva": "1.0.0-beta.4",
    "emoji-datasource-apple": "16.0.0",
    "emoji-datasource-facebook": "16.0.0",
    "emoji-datasource-google": "16.0.0",
    "emoji-datasource-twitter": "16.0.0",
    "emoji-picker-react": "4.18.0",
    "html-react-parser": "5.2.17",
    "i18next": "25.8.11",
    "i18next-http-backend": "3.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.1",
    "react-hot-toast": "2.6.0",
    "react-i18next": "16.5.4",
    "react-router": "7.13.0",
    "web-vitals": "5.1.0",
    "zod": "4.3.6",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@axe-core/react": "4.11.1",
    "@lavamoat/allow-scripts": "3.4.1",
    "@lavamoat/preinstall-always-fail": "2.1.1",
    "@playwright/test": "1.58.2",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/react": "16.3.2",
    "@tolgee/cli": "2.15.1",
    "@types/node": "24.1.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.0",
    "eslint-plugin-sonarjs": "4.0.2",
    "husky": "9.1.7",
    "jsdom": "28.1.0",
    "lint-staged": "16.2.7",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.22.1",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vite": "8.0.1",
    "vite-plugin-static-copy": "4.0.0",
    "vite-plugin-svgr": "4.5.0",
    "vitest": "4.1.0",
    "xlsx": "file:vendor/xlsx-0.20.3.tgz"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "wip",
          "feat",
          "fix",
          "docs",
          "style",
          "refactor",
          "perf",
          "test",
          "revert",
          "build",
          "ci",
          "chore"
        ]
      ]
    }
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": ">=11.10.0",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "version": "^24.0.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": "^24.0.0",
    "npm": ">=11.10.0"
  },
  "lavamoat": {
    "allowScripts": {
      "@lavamoat/preinstall-always-fail": false
    }
  }
}
